{
  "id": "unity_activity_create",
  "name": "Unity Activity Create",
  "initial": "requirement_analysis",
  "transitions": [
    { "from": "requirement_analysis", "to": "module_mapping", "when": "always" },
    { "from": "module_mapping", "to": "review_mapping", "when": "always" },
    { "from": "review_mapping", "to": "build_plan", "when": "approved" },
    { "from": "review_mapping", "to": "module_mapping", "when": "rejected" }
  ],
  "nodes": [
    {
      "id": "requirement_analysis",
      "name": "Requirement Analysis",
      "type": "ai",
      "skill": "unity_requirement_analysis",
      "inputs": {
        "raw_requirement": "Create a seasonal Unity big event with login rewards, milestone rewards, ranking rewards, and a main event page. The workflow should stay document-first and avoid direct Unity code generation in v0.2."
      },
      "outputs": {
        "primary": "requirement_analysis.md"
      },
      "approval": {
        "mode": "auto",
        "level": "optional"
      }
    },
    {
      "id": "module_mapping",
      "name": "Module Mapping",
      "type": "ai",
      "skill": "module_mapping",
      "params": {
        "unity_context": {
          "active_scene": true,
          "scene_hierarchy_depth": 3,
          "prefab_filter": "t:Prefab",
          "prefab_max": 5,
          "required": false
        }
      },
      "inputs": {
        "requirement": "artifact.requirement_analysis"
      },
      "outputs": {
        "primary": "module_mapping.md",
        "structured": "module_mapping.json"
      },
      "approval": {
        "mode": "auto",
        "level": "optional"
      }
    },
    {
      "id": "review_mapping",
      "name": "Review Module Mapping",
      "type": "review",
      "inputs": {
        "module_mapping": "artifact.module_mapping"
      },
      "approval": {
        "mode": "human",
        "level": "required"
      }
    },
    {
      "id": "build_plan",
      "name": "Build Plan",
      "type": "ai",
      "skill": "unity_build_plan",
      "inputs": {
        "module_mapping": "artifact.module_mapping"
      },
      "outputs": {
        "primary": "build_plan.md"
      },
      "approval": {
        "mode": "auto",
        "level": "optional"
      }
    }
  ]
}
