{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Workflow Foundation",
  "version": "0.1.0",
  "identifier": "com.aiwf.foundation",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "powershell -ExecutionPolicy Bypass -File src-tauri/scripts/sync-app.ps1",
    "frontendDist": "../../web"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../aiwf_cli.py": "app/aiwf_cli.py",
      "../../src/": "app/src/",
      "../../web/": "app/web/",
      "../../examples/": "app/examples/"
    }
  }
}
