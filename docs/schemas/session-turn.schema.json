{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aiwf://schemas/session-turn.schema.json",
  "title": "SessionTurn",
  "description": "One iteration turn within a NodeSession.",
  "type": "object",
  "required": ["turn", "result"],
  "properties": {
    "turn": { "type": "integer", "minimum": 1 },
    "feedback": { "type": "string" },
    "change_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "session_context": {
      "type": "object",
      "properties": {
        "prev_primary_ref": { "type": "string" },
        "prev_summary": { "type": "string" }
      }
    },
    "result": { "$ref": "execution-result.schema.json" },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" }
  }
}
